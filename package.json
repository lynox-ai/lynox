{
  "name": "@lynox-ai/core",
  "version": "1.0.0",
  "description": "One system that learns your business — replaces your CRM, workflows, outreach, and monitoring. Self-hosted, MCP server.",
  "author": "Rafael Burlet",
  "license": "Elastic-2.0",
  "homepage": "https://lynox.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lynox-ai/lynox.git"
  },
  "bugs": {
    "url": "https://github.com/lynox-ai/lynox/issues"
  },
  "keywords": [
    "ai-agent",
    "anthropic",
    "claude",
    "autonomous",
    "business-automation",
    "mcp",
    "telegram-bot",
    "pipeline",
    "memory",
    "self-hosted"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "lynox": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "node --env-file=.env --watch --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "bench": "vitest bench --config vitest.bench.config.ts",
    "bench:online": "vitest bench --config vitest.bench.config.ts tests/performance/online/",
    "smoke:manual": "bash scripts/smoke-manual.sh",
    "test:watch": "vitest",
    "prepare": "lefthook install || true",
    "security": "sh scripts/security-scan.sh && vitest run tests/security/",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@mozilla/readability": "^0.6.0",
    "@sentry/node": "^10.46.0",
    "better-sqlite3": "^12.6.2",
    "linkedom": "^0.18.12",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
