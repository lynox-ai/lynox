# ── Required ────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com/settings/keys
# Reused as the generic API key for provider: custom and provider: openai as well.
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM Provider ────────────────────────────────────────────
# Which backend serves LLM requests. Default: anthropic
# Options: anthropic | vertex | custom | openai
# LYNOX_LLM_PROVIDER=anthropic

# ── Vertex AI (provider: vertex) ────────────────────────────
# Claude via Google Cloud Vertex AI. Requires a service account JSON
# mounted into the container, with GOOGLE_APPLICATION_CREDENTIALS pointing at it.
# GCP_PROJECT_ID=
# CLOUD_ML_REGION=europe-west4
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/vertex-sa.json

# ── Custom proxy (provider: custom) ─────────────────────────
# Any Anthropic-compatible proxy (LiteLLM, Bedrock gateway, self-hosted).
# ANTHROPIC_BASE_URL=http://localhost:4000

# ── OpenAI-compatible (provider: openai) ────────────────────
# Works with OpenAI, Mistral, Groq, or any OpenAI-compatible endpoint.
# Put your key in ANTHROPIC_API_KEY (reused as the generic key).
# ANTHROPIC_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_ID=gpt-4o

# ── EU Sovereign mode (managed control plane only) ──────────
# Delivered by managed hosting on first boot. Lets end-users toggle between
# Claude and Mistral Large in the Web UI → Settings → LLM Mode.
# Self-hosted users should use provider: openai directly instead.
# LYNOX_LLM_MODE=standard
# MISTRAL_API_KEY=

# ── Recommended (auto-generated if omitted) ─────────────────
# Access token for Web UI login. If omitted, auto-generated on start (see docker logs).
# LYNOX_HTTP_SECRET=

# Encryption key for secrets vault. If omitted, auto-generated and saved to volume.
# ⚠ CRITICAL: If you lose this key, encrypted data cannot be recovered.
# Generate: openssl rand -base64 48
# LYNOX_VAULT_KEY=

# ── HTTP API ────────────────────────────────────────────────
# LYNOX_HTTP_PORT=3100
# LYNOX_TRUST_PROXY=false
# LYNOX_ALLOWED_ORIGINS=
# LYNOX_ALLOWED_IPS=

# ── TLS (native HTTPS, alternative to reverse proxy) ───────
# LYNOX_TLS_CERT=
# LYNOX_TLS_KEY=

# ── MCP server ──────────────────────────────────────────────
# LYNOX_MCP_PORT=3042
# LYNOX_MCP_SECRET=

# ── Memory scoping ──────────────────────────────────────────
# LYNOX_USER=
# LYNOX_ORG=
# LYNOX_CLIENT=

# ── Embedding provider (onnx = local ONNX, local = hash-based) ──
# LYNOX_EMBEDDING_PROVIDER=onnx

# ── Telegram bot (optional) ─────────────────────────────────
# Create a bot: t.me/BotFather → /newbot → copy token
# Chat ID: send /start to the bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_IDS=

# ── Web search ─────────────────────────────────────────────
# SearXNG is included in docker-compose — no config needed.
# For standalone docker run, set one of:
# SEARXNG_URL=http://localhost:8888
# TAVILY_API_KEY=tvly-...

# ── Google Workspace (optional) ─────────────────────────────
# Requires OAuth 2.0 setup: https://docs.lynox.ai/integrations/google-workspace/
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Error reporting (opt-in, EU region, PII scrubbed) ───────
# LYNOX_BUGSINK_DSN=

# ── Data / workspace paths ──────────────────────────────────
# LYNOX_DATA_DIR=
# LYNOX_WORKSPACE=
