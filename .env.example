# lynox — example environment file
#
# Natively supported providers (Anthropic and Mistral) are tested end-to-end
# on every release. The other provider paths (Vertex, OpenAI-compatible
# endpoints such as Ollama / LM Studio / Groq / vLLM / OpenAI itself, and
# the Anthropic-compatible "custom" proxy path) are wired but NOT regularly
# tested — use at your own risk and expect rough edges.

# ── Required ────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com/settings/keys
# Required when LYNOX_LLM_PROVIDER=anthropic (the default, and the recommended path).
# ANTHROPIC_API_KEY=sk-ant-...

# ── LLM Provider ────────────────────────────────────────────
# Which backend serves LLM requests. Default: anthropic
# Allowed values: anthropic | openai | custom | vertex
#   anthropic — Claude via api.anthropic.com (natively supported, tested)
#   openai    — Anything OpenAI-compatible. Mistral via api.mistral.ai is
#               the only EU-sovereign path we exercise on every release.
#               Other targets (OpenAI itself, Ollama, LM Studio, LiteLLM,
#               Groq, vLLM, …) are experimental.
#   custom    — Anthropic-compatible proxy (e.g. LiteLLM in Anthropic mode).
#               Experimental — wired but not regularly tested.
#   vertex    — Claude via Google Vertex AI. Legacy — wired for existing
#               config.json setups but no longer offered by the installer
#               or in-product wizard, and not regularly tested.
# LYNOX_LLM_PROVIDER=anthropic

# ── Mistral (provider: openai with Mistral defaults) ────────
# Get a key at https://console.mistral.ai/api-keys/
# The Mistral key MUST go into MISTRAL_API_KEY (canonical primary slot) or
# OPENAI_API_KEY (SDK-canonical secondary slot). It does NOT belong in
# ANTHROPIC_API_KEY — that slot is Anthropic-only and the engine will not
# pick it up for the OpenAI adapter (see src/core/llm/provider-keys.ts).
# LYNOX_LLM_PROVIDER=openai
# MISTRAL_API_KEY=<your-mistral-api-key>
# ANTHROPIC_BASE_URL=https://api.mistral.ai/v1     # shared base-url slot
# OPENAI_MODEL_ID=mistral-large-2512               # pinned snapshot; prefer over -latest (see docs/setup/llm-providers#mistral-france-eu)

# ── Custom OpenAI-compatible endpoint (provider: openai, experimental) ──
# Ollama, LM Studio, LiteLLM, Groq, vLLM, OpenAI itself, a corporate gateway, …
# Wired but not regularly tested — tool-calling reliability varies sharply
# by model and endpoint. Use OPENAI_API_KEY (SDK-canonical) or
# MISTRAL_API_KEY for the bearer token. Leave unset for keyless local
# backends (Ollama, LM Studio defaults).
# LYNOX_LLM_PROVIDER=openai
# OPENAI_API_KEY=<your-key>                        # omit for Ollama / keyless
# ANTHROPIC_BASE_URL=http://localhost:11434/v1     # shared base-url slot — Ollama default
# OPENAI_MODEL_ID=llama3.2

# ── Recommended (auto-generated if omitted) ─────────────────
# Access token for Web UI login. If omitted, auto-generated on start (see docker logs).
# LYNOX_HTTP_SECRET=

# Public origin (scheme + host + port). Required for the /login form to
# accept POST submissions — SvelteKit's CSRF guard compares the browser's
# Origin header against this value. When unset, adapter-node assumes https
# and rejects http://localhost form posts with 403 "Cross-site POST form
# submissions are forbidden". Behind a reverse proxy, use the public URL.
# ORIGIN=http://localhost:3000

# Encryption key for secrets vault. If omitted, auto-generated and saved to volume.
# ⚠ CRITICAL: If you lose this key, encrypted data cannot be recovered.
# Generate: openssl rand -base64 48
# LYNOX_VAULT_KEY=

# ── HTTP API ────────────────────────────────────────────────
# Docker default is 3000 (matches the compose port mapping). The 3100 value
# below is the local-dev default for `node dist/index.js --http-api` outside
# of Docker — uncomment only if you're running that path.
# LYNOX_HTTP_PORT=3100
# LYNOX_TRUST_PROXY=false
# LYNOX_ALLOWED_ORIGINS=
# LYNOX_ALLOWED_IPS=

# ── TLS (native HTTPS, alternative to reverse proxy) ───────
# LYNOX_TLS_CERT=
# LYNOX_TLS_KEY=

# ── Embedding provider (onnx = local ONNX, local = hash-based) ──
# LYNOX_EMBEDDING_PROVIDER=onnx

# ── Web search ─────────────────────────────────────────────
# SearXNG is included in docker-compose — no config needed.
# For standalone docker run, point at any SearXNG instance:
# SEARXNG_URL=http://localhost:8888

# ── Google Workspace (optional) ─────────────────────────────
# Requires OAuth 2.0 setup: https://docs.lynox.ai/integrations/google-workspace/
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Error reporting (opt-in, EU region, PII scrubbed) ───────
# LYNOX_BUGSINK_DSN=

# ── Data / workspace paths ──────────────────────────────────
# LYNOX_DATA_DIR=
# LYNOX_WORKSPACE=
