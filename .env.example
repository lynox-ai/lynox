# Required: Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: MCP server
NODYN_MCP_PORT=3042
NODYN_MCP_SECRET=

# Optional: Memory scoping
NODYN_USER=
NODYN_ORG=
NODYN_CLIENT=

# Optional: Secret vault
NODYN_VAULT_KEY=

# Optional: Embedding provider (onnx, voyage, local)
NODYN_EMBEDDING_PROVIDER=onnx

# Optional: Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
