# ── Required ────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com/settings/keys
# Required when LYNOX_LLM_PROVIDER=anthropic (the default).
# ANTHROPIC_API_KEY=sk-ant-...

# ── LLM Provider ────────────────────────────────────────────
# Which backend serves LLM requests. Default: anthropic
# Options: anthropic | openai
#   anthropic — Claude via api.anthropic.com (direct)
#   openai    — Anything OpenAI-compatible: Mistral, Ollama, LM Studio,
#               LiteLLM, Groq, vLLM, OpenAI itself, …
# LYNOX_LLM_PROVIDER=anthropic

# ── Mistral (provider: openai with Mistral defaults) ────────
# Get a key at https://console.mistral.ai/api-keys/
# Use MISTRAL_API_KEY (canonical) or OPENAI_API_KEY (SDK alias) — NOT
# ANTHROPIC_API_KEY: that slot is Anthropic-only and the engine will not
# pick it up for the OpenAI adapter (see src/core/llm/provider-keys.ts).
# LYNOX_LLM_PROVIDER=openai
# MISTRAL_API_KEY=<your-mistral-api-key>
# ANTHROPIC_BASE_URL=https://api.mistral.ai/v1     # shared base-url slot
# OPENAI_MODEL_ID=mistral-large-latest             # or mistral-medium-latest / codestral-latest

# ── Custom OpenAI-compatible endpoint (provider: openai) ────
# Ollama, LM Studio, LiteLLM, Groq, vLLM, OpenAI, a corporate gateway, …
# Use OPENAI_API_KEY (SDK-canonical) or MISTRAL_API_KEY for the bearer token.
# Leave unset for keyless local backends (Ollama, LM Studio defaults).
# LYNOX_LLM_PROVIDER=openai
# OPENAI_API_KEY=<your-key>                        # omit for Ollama / keyless
# ANTHROPIC_BASE_URL=http://localhost:11434/v1     # shared base-url slot — Ollama default
# OPENAI_MODEL_ID=llama3.2

# ── Recommended (auto-generated if omitted) ─────────────────
# Access token for Web UI login. If omitted, auto-generated on start (see docker logs).
# LYNOX_HTTP_SECRET=

# Encryption key for secrets vault. If omitted, auto-generated and saved to volume.
# ⚠ CRITICAL: If you lose this key, encrypted data cannot be recovered.
# Generate: openssl rand -base64 48
# LYNOX_VAULT_KEY=

# ── HTTP API ────────────────────────────────────────────────
# LYNOX_HTTP_PORT=3100
# LYNOX_TRUST_PROXY=false
# LYNOX_ALLOWED_ORIGINS=
# LYNOX_ALLOWED_IPS=

# ── TLS (native HTTPS, alternative to reverse proxy) ───────
# LYNOX_TLS_CERT=
# LYNOX_TLS_KEY=

# ── MCP server ──────────────────────────────────────────────
# LYNOX_MCP_PORT=3042
# LYNOX_MCP_SECRET=

# ── Memory scoping ──────────────────────────────────────────
# LYNOX_USER=
# LYNOX_ORG=
# LYNOX_CLIENT=

# ── Embedding provider (onnx = local ONNX, local = hash-based) ──
# LYNOX_EMBEDDING_PROVIDER=onnx

# ── Web search ─────────────────────────────────────────────
# SearXNG is included in docker-compose — no config needed.
# For standalone docker run, set one of:
# SEARXNG_URL=http://localhost:8888
# TAVILY_API_KEY=tvly-...

# ── Google Workspace (optional) ─────────────────────────────
# Requires OAuth 2.0 setup: https://docs.lynox.ai/integrations/google-workspace/
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Error reporting (opt-in, EU region, PII scrubbed) ───────
# LYNOX_BUGSINK_DSN=

# ── Data / workspace paths ──────────────────────────────────
# LYNOX_DATA_DIR=
# LYNOX_WORKSPACE=
