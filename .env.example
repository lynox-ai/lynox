# Required: Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: HTTP API
LYNOX_HTTP_PORT=3100
LYNOX_HTTP_SECRET=
LYNOX_TRUST_PROXY=false
LYNOX_ALLOWED_ORIGINS=
LYNOX_ALLOWED_IPS=

# Optional: TLS (native HTTPS)
LYNOX_TLS_CERT=
LYNOX_TLS_KEY=

# Optional: MCP server
LYNOX_MCP_PORT=3042
LYNOX_MCP_SECRET=

# Optional: Memory scoping
LYNOX_USER=
LYNOX_ORG=
LYNOX_CLIENT=

# Optional: Secret vault
LYNOX_VAULT_KEY=

# Optional: Embedding provider (onnx, voyage)
LYNOX_EMBEDDING_PROVIDER=onnx

# Optional: Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional: Error reporting (opt-in, EU region)
LYNOX_SENTRY_DSN=

# Optional: Data / workspace
LYNOX_DATA_DIR=
LYNOX_WORKSPACE=
